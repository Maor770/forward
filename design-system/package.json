{
  "name": "@maorforward/ds",
  "version": "0.1.0",
  "description": "MaorForward design system — components and tokens extracted from the maorforward.org capital-campaign site.",
  "private": true,
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "esbuild src/index.ts --bundle --format=esm --jsx=automatic --external:react --external:react-dom --external:react/jsx-runtime --outfile=dist/index.js",
    "build:css": "node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "build:dts": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build": "npm run build:js && npm run build:css && npm run build:dts"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "esbuild": "^0.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4"
  }
}
